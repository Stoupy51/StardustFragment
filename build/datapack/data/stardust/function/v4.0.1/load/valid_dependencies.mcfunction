# Waiting for a player to get the game version, but stop function if no player found
execute unless entity @p run schedule function stardust:v4.0.1/load/valid_dependencies 1t replace
execute unless entity @p run return 0
execute store result score #game_version stardust.data run data get entity @p DataVersion

# Check if the game version is supported
scoreboard players set #mcload_error stardust.data 0
execute unless score #game_version stardust.data matches 4669.. run scoreboard players set #mcload_error stardust.data 1

